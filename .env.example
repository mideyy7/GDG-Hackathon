# ─── Z.AI GLM (required — core AI engine for all agents) ──────────────────────
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# GLM model overrides (optional — defaults match the values below)
REASONING_MODEL=glm-z1-flash     # orchestrator, prospect_qualifier
GENERATOR_MODEL=glm-4.7-flash    # code generator, outreach writer
REVIEWER_MODEL=glm-4.7-flash     # code reviewer
LONGCTX_MODEL=glm-4-long         # architecture planner (128k context)

# OpenRouter fallback (optional — used if Z.AI direct API is unavailable)
OPENROUTER_API_KEY=
ZAI_OPENROUTER_MODEL=z-ai/glm-4.7-flash
ZAI_OPENROUTER_REASONING_MODEL=z-ai/glm-z1-flash

# ─── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=owner/repo-name

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Redis (session memory) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Service ports ────────────────────────────────────────────────────────────
ORCHESTRATOR_PORT=3010
OPENCLAW_ENGINE_PORT=3040
AGENT_RUNNER_PORT=3030
CEOCLAW_PORT=3050

# ─── CEOClaw founder agent ────────────────────────────────────────────────────
CEOCLAW_AGENT_ENGINE=direct          # direct | openclaw | heuristic
CEOCLAW_AUTO_START=false
CEOCLAW_LOOP_INTERVAL_MS=3600000
CEOCLAW_LANDING_PAGE_URL=https://devclaw.ai
CEOCLAW_DAILY_MESSAGE_LIMIT=20
CEOCLAW_MAX_PROSPECTS_PER_CAMPAIGN=20
CEOCLAW_MIN_FIT_SCORE=65
CEOCLAW_DEFAULT_SEARCH_QUERY=CTO startup software

# LinkedIn credentials (required for CEOClaw sales outreach)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ─── Dashboard ────────────────────────────────────────────────────────────────
VITE_CEOCLAW_API_URL=http://localhost:3050
